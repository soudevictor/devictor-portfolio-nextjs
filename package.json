{
  "name": "devictor-portfolio",
  "version": "2.0.0",
  "description": "Portfólio pessoal de João Victor Carvalho, construído com HTML, CSS, Sass e JavaScript vanilla, com animações em GSAP, efeito de digitação com Typed.js, ícones via Font Awesome e formulário enviado pelo Web3Forms.",
  "scripts": {
    "sass": "node node_modules/sass/sass.js assets/styles/sass/index.scss assets/styles/css/style.css --watch --silence-deprecation=import",
    "sass:build": "node node_modules/sass/sass.js assets/styles/sass/index.scss assets/styles/css/style.css --no-source-map --silence-deprecation=import",
    "build": "npm run sass:build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/0Carvalh0/devictor_workshop.git"
  },
  "keywords": [
    "portfolio",
    "front-end",
    "html",
    "css",
    "sass",
    "javascript",
    "gsap",
    "typed.js",
    "font-awesome"
  ],
  "author": "João Victor Carvalho de Souza",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/0Carvalh0/devictor_workshop/issues"
  },
  "homepage": "https://soudevictor.vercel.app/",
  "devDependencies": {
    "sass": "^1.101.0"
  }
}
